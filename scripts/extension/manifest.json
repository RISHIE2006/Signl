{
  "manifest_version": 3,
  "name": "Signl | AI Career Intelligence",
  "version": "1.0",
  "description": "Instant Resume Match & Gap Analysis for LinkedIn and Indeed.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*", "https://*.indeed.com/*"],
      "js": ["content.js"]
    }
  ]
}
